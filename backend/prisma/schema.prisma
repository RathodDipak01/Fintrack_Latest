// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String             @id @default(uuid())
  email        String             @unique
  fullName     String?
  phone        String?
  plan         String             @default("free")
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  holdings     PortfolioHolding[]
  watchlist    Watchlist[]
  signals      StockSignal[]
}

model PortfolioHolding {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  symbol       String
  name         String
  qty          Float
  avgCost      Float
  productType  String?
  currentPrice Float?
  sector       String?
  industry     String?
  marketCap    Float?
  source       String   @default("CSV")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Watchlist {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  symbol    String
  alertText String?
  createdAt DateTime @default(now())
}

model StockSignal {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  symbol     String
  signal     String
  confidence Int
  note       String
  createdAt  DateTime @default(now())
}
